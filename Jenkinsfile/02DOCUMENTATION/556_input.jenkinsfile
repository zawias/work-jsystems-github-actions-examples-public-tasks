pipeline {
    agent any
    stages {
        stage('Build') {
            steps {
                sh 'make'
            }
        }
        stage('Manual Stop') {
            steps {
                input message: 'Do you want to continue?', ok: 'Yes', submitter: 'any'
            }
        }
        stage('Deploy') {
            steps {
                sh 'make deploy'
            }
        }
    }
}
