pipeline {
    agent any
    tools {
        jdk 'OpenJDK 11'
        maven 'Maven 3.6.3'
        nodejs 'Node 12'
    }
    stages {
        stage('Prepare') {
            steps {
                sh 'npm install'
            }
        }
        stage('Build') {
            steps {
                sh 'mvn clean package'
            }
        }
    }
}
